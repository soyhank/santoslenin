---
/**
 * Card con la portada del PDF; al hacer clic abre un <dialog> nativo con el
 * documento completo embebido. Cero dependencias — solo el elemento <dialog>
 * del navegador (mismo enfoque "cero JS" que el resto del sitio).
 */
interface Props {
  href: string;
  cover: string;
  coverAlt: string;
  label?: string;
  class?: string;
}
const { href, cover, coverAlt, label = 'Ver documento completo', class: cls = '' } = Astro.props;
const dialogId = `pdf-${href.split('/').pop()?.replace(/\W/g, '')}`;
---

<div class:list={['not-prose', cls]}>
  <button type="button" data-pdf-open={dialogId} class="group block w-full text-left">
    <span class="relative block overflow-hidden rounded-2xl border border-line shadow-sm transition-shadow group-hover:shadow-lg">
      <img src={cover} alt={coverAlt} width="1400" height="906" class="w-full" loading="lazy" />
      <span class="absolute inset-0 flex items-end bg-gradient-to-t from-ink-900/70 via-ink-900/0 to-ink-900/0 p-5">
        <span class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 text-sm font-semibold text-ink-900 shadow-md transition-transform group-hover:scale-105">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h10l6 6v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z"/><path d="M14 4v6h6"/></svg>
          {label}
        </span>
      </span>
    </span>
  </button>

  <dialog id={dialogId} class="h-[92vh] w-[94vw] max-w-4xl rounded-2xl border-0 p-0 backdrop:bg-ink-900/80">
    <div class="flex h-full flex-col">
      <div class="flex items-center justify-between border-b border-line px-4 py-2.5">
        <span class="font-mono text-xs text-muted">{coverAlt}</span>
        <div class="flex items-center gap-3">
          <a href={href} target="_blank" rel="noopener" class="text-sm font-medium text-accent-700 hover:underline">Abrir en pestaña nueva ↗</a>
          <button type="button" data-pdf-close={dialogId} aria-label="Cerrar" class="grid h-8 w-8 place-items-center rounded-lg text-ink-700 hover:bg-surface-alt">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
          </button>
        </div>
      </div>
      <iframe src={href} title={coverAlt} class="h-full w-full flex-1" />
    </div>
  </dialog>
</div>

<script is:inline define:vars={{ dialogId }}>
  (function () {
    var dialog = document.getElementById(dialogId);
    if (!dialog) return;
    document.querySelectorAll('[data-pdf-open="' + dialogId + '"]').forEach(function (btn) {
      btn.addEventListener('click', function () { dialog.showModal(); });
    });
    document.querySelectorAll('[data-pdf-close="' + dialogId + '"]').forEach(function (btn) {
      btn.addEventListener('click', function () { dialog.close(); });
    });
    dialog.addEventListener('click', function (e) {
      if (e.target === dialog) dialog.close();
    });
  })();
</script>
