---
import { SITE, NAV } from '../config/site';
const year = new Date().getFullYear();

const redes = [
  { key: 'linkedin', label: 'LinkedIn', url: SITE.redes.linkedin },
  { key: 'instagram', label: 'Instagram', url: SITE.redes.instagram },
  { key: 'x', label: 'X', url: SITE.redes.x },
  { key: 'youtube', label: 'YouTube', url: SITE.redes.youtube },
  { key: 'github', label: 'GitHub', url: SITE.redes.github },
].filter((r) => r.url);
---

<footer class="mt-24 border-t border-line bg-surface-alt">
  <div class="mx-auto max-w-(--spacing-content) px-5 py-12">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
      <div>
        <p class="font-semibold text-ink-900">{SITE.marca}</p>
        <p class="mt-2 max-w-xs text-sm text-muted">{SITE.tagline}</p>
      </div>

      <nav aria-label="Enlaces del pie">
        <p class="text-sm font-semibold text-ink-900">Navegación</p>
        <ul class="mt-3 space-y-2">
          {
            NAV.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-muted hover:text-accent-700">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <p class="text-sm font-semibold text-ink-900">Conecta</p>
        <ul class="mt-3 space-y-2">
          {
            SITE.email && (
              <li>
                <a href={`mailto:${SITE.email}`} class="text-sm text-muted hover:text-accent-700">
                  {SITE.email}
                </a>
              </li>
            )
          }
          {
            redes.map((r) => (
              <li>
                <a
                  href={r.url}
                  rel="me noopener"
                  target="_blank"
                  class="text-sm text-muted hover:text-accent-700"
                >
                  {r.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t border-line pt-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {SITE.nombre}. Todos los derechos reservados.</p>
      <p>Hecho con Astro · Optimizado para SEO</p>
    </div>
  </div>
</footer>
