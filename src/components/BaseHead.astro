---
import { SITE } from '../config/site';
import { canonical } from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  /** Ruta relativa de la página actual (para canonical y OG url). */
  path: string;
  /** Imagen OG específica (ruta relativa en /public). */
  image?: string;
  /** 'website' para páginas, 'article' para el blog. */
  type?: 'website' | 'article';
  /** Bloques JSON-LD a inyectar. */
  schemas?: Record<string, unknown>[];
  /** Evitar indexación (gracias, plantillas, etc.). */
  noindex?: boolean;
}

const {
  title,
  description = SITE.descripcion,
  path,
  image = SITE.ogImage,
  type = 'website',
  schemas = [],
  noindex = false,
} = Astro.props;

const url = canonical(path);
const ogImageUrl = new URL(image, SITE.url).href;
const fullTitle = path === '/' ? title : `${title} | ${SITE.marca}`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={url} />
<meta name="author" content={SITE.nombre} />

{
  noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-image-preview:large" />
  )
}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.marca} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={SITE.locale} />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Iconos -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Rendimiento de fuentes -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
/>

<!-- JSON-LD -->
{
  schemas.map((schema) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
  ))
}
