---
/**
 * Publicación pública real de un cliente. No descarga ni rehostea el video/foto:
 * solo referencia el post original.
 *
 * Facebook usa el iframe directo `plugins/video.php` / `plugins/post.php`: se probó
 * en vivo y renderiza al toque. El div `.fb-video`/`.fb-post` + SDK (xfbml) quedó
 * descartado porque en pruebas reales se quedaba en blanco.
 *
 * TikTok: su embed oficial (blockquote + embed.js) se probó en vivo y se quedaba en
 * un recuadro negro vacío (TikTok bloquea agresivamente navegadores automatizados,
 * así que no se pudo confirmar si renderiza para visitantes reales). Para no arriesgar
 * una caja rota, se usa una card de enlace directo en su lugar.
 */
import type { ProjectEmbed } from '../lib/covers';

interface Props extends ProjectEmbed {
  class?: string;
}
const { kind, url, caption, source, class: cls = '' } = Astro.props;
const encoded = encodeURIComponent(url);
---

{
  kind === 'fb-video' && (
    <div class:list={['overflow-hidden rounded-2xl border border-line bg-surface-pure', cls]}>
      <iframe
        src={`https://www.facebook.com/plugins/video.php?height=500&href=${encoded}&show_text=false&width=281&t=0`}
        width="281"
        height="500"
        style="border:none;overflow:hidden;max-width:100%"
        scrolling="no"
        loading="lazy"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
        allowfullscreen
        class="mx-auto"
      />
      <p class="border-t border-line px-4 py-2 font-mono text-xs text-muted">{caption}</p>
    </div>
  )
}

{
  kind === 'fb-post' && (
    <div class:list={['overflow-hidden rounded-2xl border border-line bg-surface-pure', cls]}>
      <iframe
        src={`https://www.facebook.com/plugins/post.php?href=${encoded}&show_text=true&width=500`}
        width="500"
        height="620"
        style="border:none;overflow:hidden;max-width:100%"
        scrolling="no"
        loading="lazy"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
        allowfullscreen
        class="mx-auto"
      />
      <p class="border-t border-line px-4 py-2 font-mono text-xs text-muted">{caption}</p>
    </div>
  )
}

{
  kind === 'tiktok' && (
    <a
      href={url}
      target="_blank"
      rel="noopener"
      class:list={['group flex w-72 flex-col justify-between overflow-hidden rounded-2xl bg-ink-900 p-6 transition-transform hover:-translate-y-1', cls]}
    >
      <span class="grid h-11 w-11 place-items-center rounded-full bg-white/10 text-white">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16.5 2c.4 2.6 2.2 4.4 4.9 4.6v3.3c-1.7.1-3.2-.4-4.9-1.5v7c0 3.6-2.9 6.6-6.6 6.6S3.3 19 3.3 15.4c0-3.5 2.7-6.4 6.1-6.6v3.4a3.2 3.2 0 1 0 2.5 3.1V2h4.6z" />
        </svg>
      </span>
      <p class="mt-4 text-sm text-white/90">{caption}</p>
      <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-white group-hover:gap-2.5 transition-all">
        Ver en TikTok
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </span>
    </a>
  )
}

{
  kind === 'press' && (
    <a
      href={url}
      target="_blank"
      rel="noopener"
      class:list={['group flex w-80 flex-col justify-between overflow-hidden rounded-2xl border border-line bg-surface-pure p-6 transition-all hover:-translate-y-1 hover:border-accent-500/50 hover:shadow-lg', cls]}
    >
      <span class="grid h-11 w-11 place-items-center rounded-full bg-accent-50 text-accent-700">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 5h13a2 2 0 0 1 2 2v11a1 1 0 0 1-1 1H4V5z" /><path d="M19 8h1a1 1 0 0 1 1 1v9a1 1 0 0 1-2 0" /><line x1="7" y1="9" x2="14" y2="9" /><line x1="7" y1="12.5" x2="14" y2="12.5" /><line x1="7" y1="16" x2="11" y2="16" />
        </svg>
      </span>
      {source && <p class="mt-4 eyebrow">{source}</p>}
      <p class="mt-2 flex-1 font-display font-semibold leading-snug text-ink-900">{caption}</p>
      <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-700 group-hover:gap-2.5 transition-all">
        Leer nota
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </span>
    </a>
  )
}
