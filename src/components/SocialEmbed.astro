---
/**
 * Embed oficial de una publicación pública real (iframe/SDK de la propia plataforma).
 * No descarga ni rehostea el video/foto: solo referencia el post original, igual que
 * un embed de YouTube.
 *
 * Facebook usa el iframe directo `plugins/video.php` / `plugins/post.php`: se probó
 * en vivo y renderiza al toque. El div `.fb-video`/`.fb-post` + SDK (xfbml) quedó
 * descartado porque en pruebas reales se quedaba en blanco.
 */
import type { ProjectEmbed } from '../lib/covers';

interface Props extends ProjectEmbed {
  class?: string;
}
const { kind, url, caption, class: cls = '' } = Astro.props;
const encoded = encodeURIComponent(url);
const videoId = url.split('/video/')[1]?.split('?')[0];
---

{
  kind === 'fb-video' && (
    <div class:list={['overflow-hidden rounded-2xl border border-line bg-surface-pure', cls]}>
      <iframe
        src={`https://www.facebook.com/plugins/video.php?height=500&href=${encoded}&show_text=false&width=281&t=0`}
        width="281"
        height="500"
        style="border:none;overflow:hidden;max-width:100%"
        scrolling="no"
        loading="lazy"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
        allowfullscreen
        class="mx-auto"
      />
      <p class="border-t border-line px-4 py-2 font-mono text-xs text-muted">{caption}</p>
    </div>
  )
}

{
  kind === 'fb-post' && (
    <div class:list={['overflow-hidden rounded-2xl border border-line bg-surface-pure', cls]}>
      <iframe
        src={`https://www.facebook.com/plugins/post.php?href=${encoded}&show_text=true&width=500`}
        width="500"
        height="620"
        style="border:none;overflow:hidden;max-width:100%"
        scrolling="no"
        loading="lazy"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
        allowfullscreen
        class="mx-auto"
      />
      <p class="border-t border-line px-4 py-2 font-mono text-xs text-muted">{caption}</p>
    </div>
  )
}

{
  kind === 'tiktok' && (
    <div class:list={['overflow-hidden rounded-2xl border border-line bg-surface-pure', cls]}>
      <blockquote class="tiktok-embed" cite={url} data-video-id={videoId} style="max-width: 100%; min-width: 280px; margin: 0;">
        <section>
          <a target="_blank" rel="noopener" href={url}>
            {caption}
          </a>
        </section>
      </blockquote>
      <script is:inline async src="https://www.tiktok.com/embed.js"></script>
      <p class="border-t border-line px-4 py-2 font-mono text-xs text-muted">{caption}</p>
    </div>
  )
}
