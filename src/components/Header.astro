---
import { SITE, NAV } from '../config/site';
import Icon from './Icon.astro';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="sticky top-0 z-40 border-b border-line/80 bg-surface/85 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-(--spacing-content) items-center justify-between px-5">
    <a href="/" class="group flex items-center gap-2.5 font-display font-bold tracking-tight text-ink-900">
      <span
        class="grid h-8 w-8 place-items-center rounded-lg bg-ink-900 font-mono text-[0.8rem] font-bold text-white transition-transform group-hover:scale-105"
        aria-hidden="true"
      >SL</span>
      <span class="text-[0.95rem]">{SITE.nav}</span>
    </a>

    <nav aria-label="Navegación principal" class="hidden md:block">
      <ul class="flex items-center gap-1">
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'rounded-md px-3 py-2 text-sm font-medium transition-colors',
                  isActive(item.href)
                    ? 'text-accent-700'
                    : 'text-ink-700 hover:text-ink-900 hover:bg-surface-alt',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a
            href={SITE.redes.linkedin}
            target="_blank"
            rel="me noopener"
            class="ml-2 inline-flex items-center gap-1.5 rounded-lg bg-accent-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-accent-700"
          >
            <Icon name="linkedin" class="h-4 w-4" /> LinkedIn
          </a>
        </li>
      </ul>
    </nav>

    <details class="group relative md:hidden">
      <summary
        class="grid h-10 w-10 cursor-pointer place-items-center rounded-lg text-ink-800 hover:bg-surface-alt [&::-webkit-details-marker]:hidden"
        aria-label="Abrir menú"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </summary>
      <nav aria-label="Navegación móvil" class="absolute right-0 top-12 w-56 rounded-xl border border-line bg-surface-pure p-2 shadow-xl">
        <ul class="flex flex-col">
          {
            NAV.map((item) => (
              <li>
                <a href={item.href} class="block rounded-lg px-3 py-2.5 text-sm font-medium text-ink-700 hover:bg-surface-alt hover:text-ink-900">
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href={SITE.redes.linkedin} target="_blank" rel="me noopener" class="mt-1 flex items-center gap-1.5 rounded-lg bg-accent-600 px-3 py-2.5 text-sm font-semibold text-white">
              <Icon name="linkedin" class="h-4 w-4" /> LinkedIn
            </a>
          </li>
        </ul>
      </nav>
    </details>
  </div>
</header>
