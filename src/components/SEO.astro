---
import { SITE } from '../config/site';
import { canonical } from '../lib/seo';

interface Props {
  /** Título de la página. En páginas internas se le añade " | Santos Lenin Vilcachagua". */
  title: string;
  description?: string;
  path: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  schemas?: Record<string, unknown>[];
  noindex?: boolean;
  /** Fecha de publicación/actualización para artículos. */
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description = SITE.descripcion,
  path,
  image = SITE.ogImage,
  type = 'website',
  schemas = [],
  noindex = false,
  publishedTime,
  modifiedTime,
} = Astro.props;

const isHome = path === '/';
const fullTitle = isHome ? title : `${title} | ${SITE.nombreCorto}`;
const url = canonical(path);
const ogImageUrl = new URL(image, SITE.url).href;
const ogType = type === 'profile' ? 'profile' : type;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={url} />
<meta name="author" content={SITE.nombre} />

{
  noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  )
}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE.nombre} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${SITE.nombre} — ${SITE.rol}`} />
<meta property="og:locale" content={SITE.locale} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Iconos -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={`${SITE.nombre} — Blog`} href="/rss.xml" />

<!-- JSON-LD -->
{
  schemas.map((schema) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
