---
import '../styles/global.css';
// Fuentes self-hosted (Fontsource) — sin CDNs externos.
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/500.css';

import { SITE } from '../config/site';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  path: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  schemas?: Record<string, unknown>[];
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
}

const props = Astro.props;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <SEO {...props} />
  </head>
  <body>
    <a href="#contenido" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (function () {
        var els = document.querySelectorAll('.reveal');
        var revealAll = function () {
          for (var i = 0; i < els.length; i++) els[i].classList.add('is-visible');
        };
        document.documentElement.classList.add('js');
        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced || !('IntersectionObserver' in window)) {
          revealAll();
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            for (var i = 0; i < entries.length; i++) {
              if (entries[i].isIntersecting) {
                entries[i].target.classList.add('is-visible');
                io.unobserve(entries[i].target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach(function (el) { io.observe(el); });
        // Red de seguridad: si algún elemento nunca entra al viewport (agentes que no
        // hacen scroll: renderizadores, crawlers, capturas), revelarlo igual.
        setTimeout(revealAll, 2200);
      })();
    </script>
  </body>
</html>
