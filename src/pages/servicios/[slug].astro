---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { breadcrumbSchema, professionalServiceSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const servicios = await getCollection('servicios');
  return servicios.map((servicio) => ({
    params: { slug: servicio.id },
    props: { servicio },
  }));
}

const { servicio } = Astro.props;
const { Content } = await render(servicio);
const d = servicio.data;

const schemas = [
  professionalServiceSchema(),
  breadcrumbSchema([
    { name: 'Inicio', path: '/' },
    { name: 'Servicios', path: '/servicios' },
    { name: d.titulo, path: `/servicios/${servicio.id}` },
  ]),
];
---

<BaseLayout
  title={d.titulo}
  description={d.resumen}
  path={`/servicios/${servicio.id}`}
  schemas={schemas}
>
  <article class="mx-auto max-w-(--spacing-content) px-5 py-16">
    <nav aria-label="Migas de pan" class="mb-6 text-sm text-muted">
      <a href="/" class="hover:text-accent-700">Inicio</a> <span aria-hidden="true">/</span>
      <a href="/servicios" class="hover:text-accent-700">Servicios</a>
      <span aria-hidden="true">/</span>
      <span class="text-ink-800">{d.titulo}</span>
    </nav>

    <div class="grid gap-12 lg:grid-cols-[1fr_320px]">
      <div>
        <span class="grid h-14 w-14 place-items-center rounded-2xl bg-accent-50 text-accent-700">
          <Icon name={d.icono} class="h-7 w-7" />
        </span>
        <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-ink-900 md:text-5xl">
          {d.titulo}
        </h1>
        <p class="mt-4 text-lg text-ink-700">{d.resumen}</p>

        <div class="prose mt-10">
          <Content />
        </div>
      </div>

      <aside class="lg:pt-2">
        <div class="sticky top-24 rounded-2xl border border-line bg-surface-alt p-6">
          {
            d.incluye.length > 0 && (
              <>
                <h2 class="font-semibold text-ink-900">Qué incluye</h2>
                <ul class="mt-4 space-y-2.5">
                  {d.incluye.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-ink-700">
                      <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-accent-600" />
                      {item}
                    </li>
                  ))}
                </ul>
              </>
            )
          }
          <a
            href="/contacto"
            class="mt-6 block rounded-lg bg-accent-600 px-5 py-3 text-center font-semibold text-white transition-colors hover:bg-accent-700"
          >
            Solicitar este servicio
          </a>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
