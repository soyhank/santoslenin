---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { breadcrumbSchema } from '../../lib/seo';

const servicios = (await getCollection('servicios')).sort(
  (a, b) => a.data.orden - b.data.orden
);

const schemas = [
  breadcrumbSchema([
    { name: 'Inicio', path: '/' },
    { name: 'Servicios', path: '/servicios' },
  ]),
];
---

<BaseLayout
  title="Servicios de consultoría en marketing digital y SEO"
  description="Consultoría SEO, estrategia de marketing digital, contenido y mentoría. Servicios pensados para que tu negocio capte más clientes de forma medible."
  path="/servicios"
  schemas={schemas}
>
  <section class="mx-auto max-w-(--spacing-content) px-5 py-16">
    <nav aria-label="Migas de pan" class="mb-6 text-sm text-muted">
      <a href="/" class="hover:text-accent-700">Inicio</a> <span aria-hidden="true">/</span>
      <span class="text-ink-800">Servicios</span>
    </nav>

    <h1 class="max-w-3xl text-4xl font-extrabold tracking-tight text-ink-900 md:text-5xl">
      Servicios de consultoría
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-700">
      Cada servicio nace de la misma idea: tu marketing debe tener dirección y
      retorno. Elige por dónde empezar o conversemos para definirlo juntos.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {
        servicios.map((s) => (
          <article class="flex flex-col rounded-2xl border border-line bg-surface p-7">
            <div class="flex items-center gap-4">
              <span class="grid h-12 w-12 place-items-center rounded-xl bg-accent-50 text-accent-700">
                <Icon name={s.data.icono} />
              </span>
              <h2 class="text-xl font-bold text-ink-900">{s.data.titulo}</h2>
            </div>
            <p class="mt-4 text-ink-700">{s.data.resumen}</p>
            {s.data.incluye.length > 0 && (
              <ul class="mt-4 space-y-2">
                {s.data.incluye.slice(0, 3).map((item) => (
                  <li class="flex items-start gap-2 text-sm text-muted">
                    <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-accent-600" />
                    {item}
                  </li>
                ))}
              </ul>
            )}
            <a
              href={`/servicios/${s.id}`}
              class="mt-6 inline-block font-semibold text-accent-700 hover:underline"
            >
              Ver detalle →
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
