---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="Mensaje enviado"
  description="Gracias por escribir. Te responderé a la brevedad."
  path="/gracias"
  noindex={true}
>
  <section class="mx-auto max-w-xl px-5 py-28 text-center">
    <span class="mx-auto grid h-16 w-16 place-items-center rounded-full bg-accent-50 text-accent-700">
      <Icon name="check" class="h-8 w-8" />
    </span>
    <h1 class="mt-6 text-3xl font-extrabold tracking-tight text-ink-900">¡Mensaje enviado!</h1>
    <p class="mt-3 text-ink-700">
      Gracias por escribir. Te responderé personalmente en menos de 48 horas hábiles.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-lg bg-accent-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-accent-700"
    >
      Volver al inicio
    </a>
  </section>
</BaseLayout>
