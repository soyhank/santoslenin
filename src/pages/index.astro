---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../config/site';
import { personSchema, webSiteSchema } from '../lib/seo';

const proyectos = (await getCollection('portafolio')).sort((a, b) => a.data.orden - b.data.orden);

const posts = (await getCollection('blog', ({ data }) => !data.draft && !data.pillar))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const schemas = [personSchema(), webSiteSchema()];

const pruebas = [
  {
    eyebrow: 'Trayectoria',
    titulo: '+5 años liderando marketing y performance',
    texto:
      'Jefe de Marketing en empresas de tecnología B2B, sector financiero/inmobiliario, educación y servicios. Equipos de hasta 12 personas y presupuestos de hasta S/500,000.',
    chips: ['+5 años', 'S/500K', 'Equipos ×12'],
  },
  {
    eyebrow: 'Docencia',
    titulo: 'Docente universitario y técnico',
    texto:
      'Marketing Digital, Marketing de Contenidos, Trade Marketing, Shopper Marketing y BTL en USIL (2022–2025) e Instituto SISE (2022–2026).',
    chips: ['USIL', 'Instituto SISE'],
  },
  {
    eyebrow: 'Stack',
    titulo: 'IA, performance y analítica',
    texto:
      'IA: Claude Code, LLMs, Python, SQL, Zapier. Performance: Meta Ads, Google Ads. Analytics: Looker Studio, Power BI, HubSpot.',
    chips: ['Claude Code', 'Meta · Google Ads', 'Looker · HubSpot'],
  },
];

const pilares = [
  {
    href: '/ia-en-marketing',
    eyebrow: 'Cluster · IA en marketing',
    titulo: 'Inteligencia artificial aplicada al marketing',
    texto: 'Guía completa con casos reales: investigación, automatización y analítica potenciadas con IA.',
  },
  {
    href: '/geo-aeo',
    eyebrow: 'Cluster · GEO / AEO',
    titulo: 'GEO y AEO: posicionar tu marca en los motores de IA',
    texto: 'Cómo aparecer en ChatGPT, Gemini y Perplexity, y en qué se diferencia del SEO clásico.',
  },
];

const fmt = (d: Date) => d.toLocaleDateString('es-PE', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title={SITE.nombre} description={SITE.descripcion} path="/" schemas={schemas}>
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-line">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-accent-50/70 via-surface to-surface"></div>
    <div class="mx-auto grid max-w-(--spacing-content) items-center gap-10 px-5 py-16 md:py-24 lg:grid-cols-[1.4fr_1fr]">
      <div>
        <p class="eyebrow">Marketing Digital · Performance · IA</p>
        <h1 class="mt-3 font-display text-4xl font-bold leading-[1.05] tracking-tight text-ink-900 md:text-6xl">
          {SITE.nombre}
        </h1>
        <p class="mt-5 max-w-xl text-lg text-ink-700 md:text-xl">
          {SITE.tesis}
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          <span class="chip chip-strong">+5 años</span>
          <span class="chip chip-strong">S/500K gestionados</span>
          <span class="chip chip-strong">Equipos de hasta 12</span>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/portafolio" class="rounded-lg bg-accent-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-accent-700">
            Ver portafolio
          </a>
          <a
            href={SITE.redes.linkedin}
            target="_blank"
            rel="me noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-line bg-surface-pure px-6 py-3 font-semibold text-ink-800 transition-colors hover:bg-surface-alt"
          >
            <Icon name="linkedin" class="h-4 w-4" /> LinkedIn
          </a>
        </div>
      </div>

      <!-- Retrato -->
      <div class="relative mx-auto w-full max-w-xs lg:max-w-none">
        <div class="aspect-[4/5] overflow-hidden rounded-3xl border border-line shadow-xl">
          <img
            src="/santos-lenin-vilcachagua.jpg"
            width="640"
            height="800"
            alt={SITE.nombre}
            class="h-full w-full object-cover"
            loading="eager"
          />
        </div>
        <span class="chip chip-strong absolute -bottom-3 -left-3 shadow-md">Performance + IA</span>
      </div>
    </div>
  </section>

  <!-- PRUEBA -->
  <section class="mx-auto max-w-(--spacing-content) px-5 py-16">
    <div class="grid gap-5 md:grid-cols-3">
      {
        pruebas.map((p) => (
          <div class="reveal rounded-2xl border border-line bg-surface-pure p-6">
            <p class="eyebrow">{p.eyebrow}</p>
            <h2 class="mt-2 font-display text-lg font-semibold text-ink-900">{p.titulo}</h2>
            <p class="mt-2 text-sm text-muted">{p.texto}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {p.chips.map((c) => <span class="chip">{c}</span>)}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- PORTAFOLIO -->
  <section class="border-y border-line bg-surface-alt">
    <div class="mx-auto max-w-(--spacing-content) px-5 py-16">
      <div class="reveal flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-2xl">
          <p class="eyebrow">Portafolio</p>
          <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900">Proyectos liderados</h2>
          <p class="mt-3 text-ink-700">Proyectos de marketing y performance que ejecuté y concluí, con su contexto, estrategia y resultados.</p>
        </div>
        <a href="/portafolio" class="font-medium text-accent-700 hover:underline">Ver todos →</a>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {proyectos.map((p) => <PortfolioCard proyecto={p} />)}
      </div>
    </div>
  </section>

  <!-- CONTENIDO -->
  <section class="mx-auto max-w-(--spacing-content) px-5 py-16">
    <div class="reveal max-w-2xl">
      <p class="eyebrow">Contenido</p>
      <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-ink-900">Dos temas que domino y comparto</h2>
      <p class="mt-3 text-ink-700">Escribo sobre IA aplicada al marketing y sobre GEO/AEO: cómo posicionar marcas y personas en los nuevos motores de búsqueda con IA.</p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {
        pilares.map((p) => (
          <a href={p.href} class="reveal group rounded-2xl border border-line bg-surface-pure p-7 transition-all hover:-translate-y-1 hover:border-accent-500/50 hover:shadow-lg">
            <p class="eyebrow">{p.eyebrow}</p>
            <h3 class="mt-2 font-display text-xl font-semibold text-ink-900">{p.titulo}</h3>
            <p class="mt-2 text-muted">{p.texto}</p>
            <span class="mt-4 inline-block font-medium text-accent-700 group-hover:underline">Leer la guía →</span>
          </a>
        ))
      }
    </div>

    {
      posts.length > 0 && (
        <div class="mt-10">
          <p class="eyebrow">Últimos artículos</p>
          <div class="mt-4 grid gap-5 sm:grid-cols-3">
            {posts.map((post) => (
              <a href={`/blog/${post.id}`} class="reveal group rounded-2xl border border-line bg-surface-pure p-6 transition-shadow hover:shadow-lg">
                <time class="font-mono text-xs text-muted" datetime={post.data.pubDate.toISOString()}>
                  {fmt(post.data.pubDate)}
                </time>
                <h3 class="mt-2 font-display text-base font-semibold leading-snug text-ink-900 group-hover:text-accent-700">
                  {post.data.title}
                </h3>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-(--spacing-content) px-5 pb-20">
    <div class="reveal overflow-hidden rounded-3xl bg-ink-900 px-8 py-14 text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-white md:text-4xl">¿Buscas un especialista de marketing que entregue resultados?</h2>
      <p class="mx-auto mt-4 max-w-xl text-slate-300">Conversemos sobre tu equipo, tu proyecto o una oportunidad. Estoy abierto a nuevos retos profesionales.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/contacto" class="rounded-lg bg-accent-500 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-accent-600">Contacto</a>
        <a href="/cv" class="rounded-lg border border-white/20 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-white/10">Ver mi CV</a>
      </div>
    </div>
  </section>
</BaseLayout>
