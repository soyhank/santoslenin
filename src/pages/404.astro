---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe o fue movida."
  path="/404"
  noindex={true}
>
  <section class="mx-auto max-w-xl px-5 py-28 text-center">
    <p class="text-6xl font-extrabold text-accent-500">404</p>
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-ink-900">Página no encontrada</h1>
    <p class="mt-3 text-ink-700">
      La página que buscas no existe o cambió de lugar.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="rounded-lg bg-accent-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-accent-700"
      >
        Ir al inicio
      </a>
      <a
        href="/servicios"
        class="rounded-lg border border-line bg-surface px-6 py-3 font-semibold text-ink-800 hover:bg-surface-alt"
      >
        Ver servicios
      </a>
    </div>
  </section>
</BaseLayout>
