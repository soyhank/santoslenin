---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../config/site';
import { breadcrumbSchema } from '../lib/seo';

const schemas = [
  breadcrumbSchema([
    { name: 'Inicio', path: '/' },
    { name: 'Contacto', path: '/contacto' },
  ]),
];

const canales = [
  {
    icon: 'mail',
    label: 'Correo',
    valor: SITE.email,
    href: `mailto:${SITE.email}`,
    desc: 'La vía más directa. Respondo personalmente.',
  },
  {
    icon: 'linkedin',
    label: 'LinkedIn',
    valor: '/in/santos-lenin-vilcachagua-ayala',
    href: SITE.redes.linkedin,
    desc: 'Conectemos y conversemos sobre oportunidades.',
  },
  {
    icon: 'youtube',
    label: 'YouTube',
    valor: 'Canal de contenido',
    href: SITE.redes.youtube,
    desc: 'Contenido sobre marketing, performance e IA.',
  },
];
---

<BaseLayout
  title="Contacto"
  description="Conecta con Santos Lenin Vilcachagua Ayala, especialista en marketing digital y performance. Correo y LinkedIn para oportunidades y proyectos."
  path="/contacto"
  schemas={schemas}
>
  <section class="mx-auto max-w-(--spacing-content) px-5 py-16">
    <nav aria-label="Migas de pan" class="mb-6 font-mono text-xs text-muted">
      <a href="/" class="hover:text-accent-700">Inicio</a> / <span class="text-ink-800">Contacto</span>
    </nav>

    <div class="max-w-2xl">
      <p class="eyebrow">Hablemos</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-ink-900 md:text-5xl">Contacto</h1>
      <p class="mt-4 text-lg text-ink-700">
        Estoy abierto a nuevos retos profesionales y colaboraciones en marketing digital,
        performance e inteligencia artificial aplicada al marketing. Escríbeme por el canal
        que prefieras.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-3">
      {
        canales.map((c) => (
          <a
            href={c.href}
            target={c.icon === 'mail' ? undefined : '_blank'}
            rel={c.icon === 'mail' ? undefined : 'me noopener'}
            class="group flex flex-col rounded-2xl border border-line bg-surface-pure p-6 transition-all hover:-translate-y-1 hover:border-accent-500/50 hover:shadow-lg"
          >
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-accent-50 text-accent-700">
              <Icon name={c.icon} class="h-5 w-5" />
            </span>
            <h2 class="mt-4 font-display font-semibold text-ink-900">{c.label}</h2>
            <p class="mt-1 flex-1 text-sm text-muted">{c.desc}</p>
            <span class="mt-3 break-all font-mono text-xs text-accent-700">{c.valor}</span>
          </a>
        ))
      }
    </div>

    <p class="mt-10 font-mono text-sm text-muted">📍 Lima, Perú · Disponible para trabajo remoto e híbrido</p>
  </section>
</BaseLayout>
