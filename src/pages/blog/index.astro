---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../../lib/seo';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publicado.getTime() - a.data.publicado.getTime()
);

const schemas = [
  breadcrumbSchema([
    { name: 'Inicio', path: '/' },
    { name: 'Blog', path: '/blog' },
  ]),
];

const fmt = (d: Date) =>
  d.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Blog sobre marketing digital y SEO"
  description="Artículos prácticos sobre SEO, marketing digital y crecimiento de negocios. Estrategias claras y honestas para aplicar hoy."
  path="/blog"
  schemas={schemas}
>
  <section class="mx-auto max-w-(--spacing-content) px-5 py-16">
    <nav aria-label="Migas de pan" class="mb-6 text-sm text-muted">
      <a href="/" class="hover:text-accent-700">Inicio</a> <span aria-hidden="true">/</span>
      <span class="text-ink-800">Blog</span>
    </nav>

    <h1 class="text-4xl font-extrabold tracking-tight text-ink-900 md:text-5xl">Blog</h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-700">
      Ideas prácticas sobre SEO, marketing digital y crecimiento. Sin humo: lo que
      realmente mueve la aguja.
    </p>

    {
      posts.length === 0 ? (
        <p class="mt-12 text-muted">Pronto publicaré los primeros artículos.</p>
      ) : (
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {posts.map((post) => (
            <article class="flex flex-col rounded-2xl border border-line bg-surface p-7 transition-shadow hover:shadow-lg">
              <div class="flex items-center gap-3 text-xs text-muted">
                <span class="rounded-full bg-accent-50 px-2.5 py-0.5 font-medium text-accent-700">
                  {post.data.categoria}
                </span>
                <time datetime={post.data.publicado.toISOString()}>{fmt(post.data.publicado)}</time>
              </div>
              <h2 class="mt-3 text-xl font-bold text-ink-900">
                <a href={`/blog/${post.id}`} class="hover:text-accent-700">
                  {post.data.titulo}
                </a>
              </h2>
              <p class="mt-2 flex-1 text-sm text-muted">{post.data.descripcion}</p>
              <a
                href={`/blog/${post.id}`}
                class="mt-4 font-medium text-accent-700 hover:underline"
              >
                Leer artículo →
              </a>
            </article>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
