---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import CoverArt from '../../components/CoverArt.astro';
import { SITE } from '../../config/site';
import { articleSchema, faqSchema, breadcrumbSchema } from '../../lib/seo';
import { getBlogCover } from '../../lib/covers';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && !data.pillar);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const path = `/blog/${post.id}`;

const schemas: Record<string, unknown>[] = [
  articleSchema({ title: d.title, description: d.description, path, pubDate: d.pubDate, updatedDate: d.updatedDate }),
  breadcrumbSchema([
    { name: 'Inicio', path: '/' },
    { name: 'Blog', path: '/blog' },
    { name: d.title, path },
  ]),
];
if (d.faq && d.faq.length) schemas.push(faqSchema(d.faq));

const fmt = (date: Date) => date.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });
const cover = getBlogCover(d.cluster);
---

<BaseLayout
  title={d.title}
  description={d.description}
  path={path}
  type="article"
  schemas={schemas}
  publishedTime={d.pubDate.toISOString()}
  modifiedTime={(d.updatedDate ?? d.pubDate).toISOString()}
>
  <CoverArt seed={post.id} icon={cover.icon} variant={cover.variant} class="aspect-[21/9] w-full" />
  <article class="mx-auto max-w-3xl px-5 py-16">
    <nav aria-label="Migas de pan" class="mb-6 font-mono text-xs text-muted">
      <a href="/" class="hover:text-accent-700">Inicio</a> / <a href="/blog" class="hover:text-accent-700">Blog</a> /
      <span class="text-ink-800">{d.title}</span>
    </nav>

    <p class="eyebrow">{d.cluster === 'ia-marketing' ? 'IA en marketing' : 'GEO / AEO'}</p>
    <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight text-ink-900">{d.title}</h1>
    <p class="mt-4 text-lg text-ink-700">{d.description}</p>

    <div class="mt-6 flex flex-wrap items-center gap-3 border-t border-line pt-6 font-mono text-xs text-muted">
      <span class="font-medium text-ink-800">{SITE.nombre}</span>
      <span aria-hidden="true">·</span>
      <time datetime={d.pubDate.toISOString()}>{fmt(d.pubDate)}</time>
      {d.updatedDate && <><span aria-hidden="true">·</span><span>Actualizado {fmt(d.updatedDate)}</span></>}
    </div>

    <div class="prose mt-8">
      <Content />
    </div>

    {
      d.faq && d.faq.length > 0 && (
        <section class="mt-14">
          <h2 class="font-display text-2xl font-bold text-ink-900">Preguntas frecuentes</h2>
          <dl class="mt-6 divide-y divide-line border-y border-line">
            {d.faq.map((f) => (
              <div class="py-5">
                <dt class="font-display font-semibold text-ink-900">{f.pregunta}</dt>
                <dd class="mt-2 text-ink-700">{f.respuesta}</dd>
              </div>
            ))}
          </dl>
        </section>
      )
    }

    <RelatedContent cluster={d.cluster} currentId={post.id} />
  </article>
</BaseLayout>
